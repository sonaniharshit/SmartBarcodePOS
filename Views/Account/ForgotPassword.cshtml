@model ForgotPasswordViewModel
@{
    Layout = null;
    ViewData["Title"] = "Forgot Password";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Forgot Password - Smart Barcode POS</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="~/lib/bootstrap/css/bootstrap.min.css" rel="stylesheet">
    <link href="~/lib/font-awesome/css/all.min.css" rel="stylesheet">
    <link href="~/css/auth.css" rel="stylesheet" asp-append-version="true" />
</head>
<body class="auth-body">
    <div class="auth-page-center">
        <div class="auth-card">
            <div class="auth-card-header">
                <div class="auth-icon"><i class="fa-solid fa-unlock-keyhole"></i></div>
                <h4>Forgot Password</h4>
                <p>Enter your email to receive reset instructions.</p>
            </div>

            <form asp-action="ForgotPassword" method="post">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label asp-for="Email" class="form-label">Email Address <span class="text-danger">*</span></label>
                    <div class="input-wrap">
                        <i class="fa-solid fa-envelope input-icon"></i>
                        <input asp-for="Email" class="form-control" placeholder="Enter registered email" />
                    </div>
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <button class="btn btn-primary btn-main w-100">
                    <i class="fa-solid fa-paper-plane me-2"></i>Send Reset Link
                </button>
            </form>

            <div class="text-center mt-3">
                <a asp-action="Login" class="text-decoration-none fw-semibold">Back to Login</a>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/jquery.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
</body>
</html>
