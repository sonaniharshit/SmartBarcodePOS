@model List<Category>
@{
    ViewData["Title"] = "Category List";
}

<div class="card">
    <div class="card-header bg-white border-0 pt-4 px-4 d-flex justify-content-between align-items-center flex-wrap gap-2">
        <div>
            <h5 class="fw-bold mb-0">Category List</h5>
            <small class="text-muted">
                Categories are linked with brands.
                Product page shows category based on selected brand.
            </small>
        </div>
        <a asp-action="Create" class="btn btn-primary">
            <i class="fa-solid fa-plus me-1"></i> Add Category
        </a>
    </div>

    <div class="card-body table-responsive">
        <table class="table table-hover align-middle datatable">
            <thead>
                <tr>
                    <th>Brand</th>
                    <th>Category Name</th>
                    <th>Status</th>
                    <th style="width: 260px;">Actions</th>
                </tr>
            </thead>
            <tbody>
            @if (Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Brand?.BrandName</td>
                        <td class="fw-semibold">@item.CategoryName</td>
                        <td>
                            @if (item.IsActive)
                            {
                                <span class="badge badge-soft-success">Active</span>
                            }
                            else
                            {
                                <span class="badge badge-soft-danger">Inactive</span>
                            }
                        </td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@item.CategoryId"
                               class="btn btn-sm btn-outline-success">
                                <i class="fa-solid fa-pen"></i>
                            </a>

                            <form asp-action="ToggleStatus" asp-route-id="@item.CategoryId"
                                  method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit"
                                        class="btn btn-sm @(item.IsActive ? "btn-outline-warning" : "btn-outline-primary")">
                                    @if (item.IsActive)
                                    {
                                        <span><i class="fa-solid fa-ban"></i></span>
                                    }
                                    else
                                    {
                                        <span><i class="fa-solid fa-check"></i></span>
                                    }
                                </button>
                            </form>

                            <form asp-action="Delete" asp-route-id="@item.CategoryId"
                                  method="post" class="d-inline delete-form">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    <i class="fa-solid fa-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        $('.delete-form').on('submit', function (e) {
            if (!confirm('Delete this category?')) e.preventDefault();
        });
    </script>
}
