@model List<SmartBarcodePOS_Pro.ViewModels.TopSellingProductViewModel>
@{
    ViewData["Title"] = "Top Selling Products";
}

<div class="card">
    <div class="card-header bg-white border-0 pt-4 px-4">
        <h5 class="fw-bold mb-0">Top Selling Products</h5>
        <small class="text-muted">Products sorted by sold quantity.</small>
    </div>
    <div class="card-body table-responsive">
        <table class="table table-hover datatable">
            <thead>
                <tr>
                    <th>Product</th>
                    <th>Total Qty</th>
                    <th>Total Amount</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.ProductName</td>
                        <td>@item.TotalQty</td>
                        <td>₹@item.TotalAmount</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
