@{
    Layout = null;
    ViewData["Title"] = "Cashier POS";
    var cashierName = User.FindFirst("FullName")?.Value ?? User.Identity?.Name ?? "Cashier";
    var avatarLetter = string.IsNullOrWhiteSpace(cashierName) ? "C" : cashierName.Substring(0, 1).ToUpper();
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Cashier POS - Smart Barcode POS</title>
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="theme-color" content="#0b1f3a" />

    <link href="~/lib/bootstrap/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/lib/font-awesome/css/all.min.css" rel="stylesheet" />
    <link href="~/lib/toastr.js/toastr.min.css" rel="stylesheet" />
    <link href="~/css/cashier-portal.css" rel="stylesheet" asp-append-version="true" />
</head>
<body class="cashier-body">

    @* DESKTOP BLOCK SCREEN *@
    <div class="desktop-block" id="desktopBlock">
        <div class="desktop-block-card">
            <div class="desktop-block-icon">
                <i class="fa-solid fa-mobile-screen-button"></i>
            </div>
            <h2>Mobile Only</h2>
            <p>The Cashier Portal is designed exclusively for mobile devices. Please open this on your phone or tablet.</p>
            <div class="desktop-block-badge">
                <i class="fa-solid fa-shield-halved me-2"></i>Cashier Access
            </div>
        </div>
    </div>

    <div class="cashier-app" id="cashierApp">

        @* TOP NAV BAR  *@
        <header class="cashier-topbar">
            <div class="cashier-topbar-left">
                <div class="cashier-avatar">@avatarLetter</div>
                <div class="cashier-topbar-info">
                    <span class="cashier-topbar-name">@cashierName</span>
                    <span class="cashier-topbar-role">
                        <i class="fa-solid fa-circle-dot me-1" style="color:#22c55e;font-size:8px;"></i>Cashier
                    </span>
                </div>
            </div>
            <div class="cashier-topbar-right">
                <div class="cashier-cart-badge-wrap" id="cartNavBadgeWrap">
                    <button class="cashier-icon-btn" id="btnViewCart" title="View Cart">
                        <i class="fa-solid fa-cart-shopping"></i>
                        <span class="cashier-cart-count" id="cartNavCount" style="display:none;">0</span>
                    </button>
                </div>
                <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="cashier-icon-btn cashier-logout-btn" title="Logout">
                        <i class="fa-solid fa-right-from-bracket"></i>
                    </button>
                </form>
            </div>
        </header>

        @* MAIN CONTENT  *@
        <main class="cashier-content">

            @* TAB 1: SCAN  *@
            <div class="cashier-tab-pane active" id="tab-scan">

                @* Camera Scanner Card  *@
                <div class="cashier-card scan-card">
                    <div class="scan-card-header">
                        <div class="scan-card-title">
                            <i class="fa-solid fa-camera-viewfinder me-2"></i>Barcode Scanner
                        </div>
                        <div class="scan-controls">
                            <button class="cashier-btn cashier-btn-primary" id="btnStartScanner">
                                <i class="fa-solid fa-camera me-1"></i>Open
                            </button>
                            <button class="cashier-btn cashier-btn-danger" id="btnStopScanner">
                                <i class="fa-solid fa-stop me-1"></i>Stop
                            </button>
                        </div>
                    </div>

                    @* Camera Viewfinder *@
                    <div id="reader" class="cashier-reader">
                        <div class="cashier-reader-placeholder">
                            <div class="scanner-frame">
                                <div class="scanner-corner tl"></div>
                                <div class="scanner-corner tr"></div>
                                <div class="scanner-corner bl"></div>
                                <div class="scanner-corner br"></div>
                            </div>
                            <i class="fa-solid fa-camera fa-2x mb-3" style="color:#94a3b8;"></i>
                            <p class="mb-0" style="color:#64748b;font-size:14px;">Tap <b>Open</b> to start scanning</p>
                        </div>
                    </div>
                </div>

                @* Manual SKU Input Card *@
                <div class="cashier-card sku-card">
                    <div class="sku-card-label">
                        <i class="fa-solid fa-keyboard me-2"></i>Manual Entry
                    </div>
                    <div class="sku-input-row">
                        <input id="manualSku"
                               class="cashier-input"
                               placeholder="Type product code / barcode"
                               inputmode="text"
                               autocomplete="off"
                               autocorrect="off"
                               spellcheck="false" />
                        <button id="btnFindProduct" class="cashier-btn cashier-btn-dark">
                            <i class="fa-solid fa-magnifying-glass"></i>
                        </button>
                    </div>
                </div>

                @* Product Preview Card *@
                <div class="cashier-card product-preview-card d-none" id="productPreview">
                    <div class="product-preview-inner">
                        <div class="product-preview-icon">
                            <i class="fa-solid fa-box-open"></i>
                        </div>
                        <div class="product-preview-info">
                            <div class="product-preview-name" id="previewName"></div>
                            <div class="product-preview-meta">
                                <span class="preview-sku" id="previewSku"></span>
                                <span class="preview-dot">•</span>
                                <span id="previewCategory"></span>
                            </div>
                            <div class="product-preview-stock">
                                <i class="fa-solid fa-cubes me-1"></i>Stock: <b id="previewStock"></b>
                            </div>
                        </div>
                        <div class="product-preview-price-col">
                            <div class="product-preview-price">₹<span id="previewPrice"></span></div>
                            <button class="cashier-btn cashier-btn-success cashier-btn-sm mt-2" id="btnAddToCart">
                                <i class="fa-solid fa-plus me-1"></i>Add
                            </button>
                        </div>
                    </div>
                </div>

            </div>

            @* TAB 2: CART *@
            <div class="cashier-tab-pane" id="tab-cart">

                <div class="cashier-card cart-card">
                    <div class="cart-card-header">
                        <div class="cart-card-title">
                            <i class="fa-solid fa-cart-shopping me-2"></i>Cart Items
                        </div>
                        <button class="cashier-btn cashier-btn-outline-danger cashier-btn-sm" id="btnClearCart">
                            <i class="fa-solid fa-trash me-1"></i>Clear
                        </button>
                    </div>

                    <div id="cartList" class="cart-list">
                        <div class="cart-empty" id="cartEmpty">
                            <i class="fa-solid fa-cart-shopping fa-3x mb-3" style="color:#cbd5e1;"></i>
                            <p>No items in cart</p>
                            <small>Scan products to add them here</small>
                        </div>
                    </div>
                </div>

                @* Cart Summary Strip  *@
                <div class="cart-summary-strip" id="cartSummaryStrip" style="display:none;">
                    <div class="cart-summary-row">
                        <span><i class="fa-solid fa-layer-group me-1"></i><span id="cartSummaryItems">0</span> items</span>
                        <span><i class="fa-solid fa-hashtag me-1"></i><span id="cartSummaryQty">0</span> qty</span>
                    </div>
                    <button class="cashier-btn cashier-btn-primary cashier-btn-block" onclick="switchTab('bill')">
                        <i class="fa-solid fa-receipt me-2"></i>View Bill Summary
                    </button>
                </div>

            </div>

             @* TAB 3: BILL  *@
            <div class="cashier-tab-pane" id="tab-bill">

                <div class="cashier-card bill-card">
                    <div class="bill-card-title">
                        <i class="fa-solid fa-file-invoice-dollar me-2"></i>Bill Summary
                    </div>

                    @* Stats Row *@
                    <div class="bill-stats-row">
                        <div class="bill-stat">
                            <span class="bill-stat-label">Items</span>
                            <span class="bill-stat-value" id="billTotalItems">0</span>
                        </div>
                        <div class="bill-stat">
                            <span class="bill-stat-label">Quantity</span>
                            <span class="bill-stat-value" id="billTotalQty">0</span>
                        </div>
                    </div>

                    @* Divider *@
                    <div class="bill-divider"></div>

                    @* Discount Row  *@
                    <div class="discount-row">
                        <label class="discount-label">
                            <i class="fa-solid fa-tag me-1"></i>Discount %
                        </label>
                        <div class="discount-input-wrap">
                            <button class="discount-btn" onclick="adjustDiscount(-5)">
                                <i class="fa-solid fa-minus"></i>
                            </button>
                            <input id="discountPercent"
                                   type="number"
                                   class="discount-field"
                                   value="0"
                                   min="0"
                                   max="100"
                                   step="1" />
                            <button class="discount-btn" onclick="adjustDiscount(5)">
                                <i class="fa-solid fa-plus"></i>
                            </button>
                        </div>
                    </div>

                    @* Totals  *@
                    <div class="bill-totals">
                        <div class="bill-total-row">
                            <span>Subtotal</span>
                            <span id="subTotal">₹0.00</span>
                        </div>
                        <div class="bill-total-row discount-line">
                            <span><i class="fa-solid fa-tag me-1"></i>Discount</span>
                            <span id="discountAmountDisplay">₹0.00</span>
                        </div>
                        <div class="bill-total-row grand-total-row">
                            <span>Grand Total</span>
                            <span id="grandTotal" class="grand-total-amount">₹0.00</span>
                        </div>
                    </div>

                    @* Generate Bill Button *@
                    <button id="btnGenerateBill" class="cashier-btn cashier-btn-success cashier-btn-block cashier-btn-generate">
                        <i class="fa-solid fa-print me-2"></i>Generate &amp; Print Bill
                    </button>
                </div>

            </div>

        </main>

        @* BOTTOM NAV BAR *@
        <nav class="cashier-bottom-nav">
            <button class="cashier-nav-btn active" data-tab="scan" onclick="switchTab('scan')">
                <i class="fa-solid fa-barcode"></i>
                <span>Scan</span>
            </button>
            <button class="cashier-nav-btn" data-tab="cart" onclick="switchTab('cart')">
                <i class="fa-solid fa-cart-shopping"></i>
                <span>Cart</span>
                <span class="nav-badge" id="navCartBadge" style="display:none;">0</span>
            </button>
            <button class="cashier-nav-btn" data-tab="bill" onclick="switchTab('bill')">
                <i class="fa-solid fa-receipt"></i>
                <span>Bill</span>
            </button>
        </nav>

    </div>

    <script src="~/lib/jquery/jquery.min.js"></script>
    <script src="~/lib/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/toastr.js/toastr.min.js"></script>
    <script src="~/lib/html5-qrcode/html5-qrcode.min.js"></script>
    <script src="~/js/cashier-portal.js" asp-append-version="true"></script>

    <script>
        toastr.options = {
            closeButton: true,
            progressBar: true,
            positionClass: 'toast-top-center',
            timeOut: '2500',
        };

        @if (TempData["Success"] != null) { <text>toastr.success('@TempData["Success"]');</text> }
        @if (TempData["Error"] != null) { <text>toastr.error('@TempData["Error"]');</text> }
    </script>

</body>
</html>
