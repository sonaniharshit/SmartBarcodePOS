@model CustomerViewModel
@{ ViewData["Title"] = "Add Customer"; }

<div class="card">
    <div class="card-header bg-white border-0 pt-4 px-4">
        <h5 class="fw-bold mb-0">Add Customer</h5>
    </div>
    <div class="card-body p-4">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()

            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="CustomerName" class="form-label">Customer Name <span class="text-danger">*</span></label>
                    <input asp-for="CustomerName" class="form-control" placeholder="Customer name" />
                    <span asp-validation-for="CustomerName" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="MobileNo" class="form-label">Mobile Number <span class="text-danger">*</span></label>
                    <input asp-for="MobileNo" class="form-control" placeholder="Mobile number" />
                    <span asp-validation-for="MobileNo" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="LoyaltyPoints" class="form-label"></label>
                    <input asp-for="LoyaltyPoints" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="IsActive" class="form-label">Status</label>
                    <select asp-for="IsActive" class="form-select">
                        <option value="true">Active</option>
                        <option value="false">Inactive</option>
                    </select>
                </div>
                <div class="col-12">
                    <label asp-for="Address" class="form-label"></label>
                    <textarea asp-for="Address" class="form-control" rows="3"></textarea>
                </div>
            </div>

            <div class="mt-4">
                <button class="btn btn-success px-4"><i class="fa-solid fa-floppy-disk me-1"></i> Save Customer</button>
                <a asp-action="Index" class="btn btn-light">Cancel</a>
            </div>
        </form>
    </div>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
