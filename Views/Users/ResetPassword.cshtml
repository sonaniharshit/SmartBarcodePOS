@model AdminResetPasswordViewModel
@{
    ViewData["Title"] = "Reset User Password";
}

<div class="card">
    <div class="card-header bg-white border-0 pt-4 px-4">
        <h5 class="fw-bold mb-0">Reset User Password</h5>
        <small class="text-muted">Set a new password for @ViewBag.UserName (@ViewBag.Email).</small>
    </div>

    <div class="card-body p-4">
        <form asp-action="ResetPassword" method="post" class="row g-3">
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden" />
            <div asp-validation-summary="ModelOnly" class="text-danger small"></div>

            <div class="col-md-6">
                <label asp-for="NewPassword" class="form-label">New Password <span class="text-danger">*</span></label>
                <div class="password-field-wrap">
                    <input asp-for="NewPassword" id="newPassword" class="form-control" />
                    <button type="button" class="password-eye-btn" onclick="togglePassword('newPassword','eye1')">
                        <i class="fa-solid fa-eye" id="eye1"></i>
                    </button>
                </div>
                <span asp-validation-for="NewPassword" class="text-danger small"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="ConfirmPassword" class="form-label">Confirm Password <span class="text-danger">*</span></label>
                <div class="password-field-wrap">
                    <input asp-for="ConfirmPassword" id="confirmPassword" class="form-control" />
                    <button type="button" class="password-eye-btn" onclick="togglePassword('confirmPassword','eye2')">
                        <i class="fa-solid fa-eye" id="eye2"></i>
                    </button>
                </div>
                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
            </div>

            <div class="col-12 d-flex gap-2">
                <button class="btn btn-success px-4">
                    <i class="fa-solid fa-key me-1"></i> Reset Password
                </button>
                <a asp-action="Index" class="btn btn-light px-4">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function togglePassword(inputId, iconId){
            const input = document.getElementById(inputId);
            const icon = document.getElementById(iconId);
            if(input.type === 'password'){ input.type='text'; icon.classList.replace('fa-eye','fa-eye-slash'); }
            else{ input.type='password'; icon.classList.replace('fa-eye-slash','fa-eye'); }
        }
    </script>
}
